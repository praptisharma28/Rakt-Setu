# Server Configuration
PORT=8080
DEV_MODE=development

# MongoDB Atlas Connection
# Replace <username>, <password>, and <cluster-url> with your MongoDB Atlas credentials
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/rakt-setu?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/rakt-setu?retryWrites=true&w=majority

# JWT Secret Key (Generate a strong random string)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration (optional)
JWT_EXPIRE=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_MAX=100
